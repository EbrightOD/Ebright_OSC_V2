generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model attendance {
  attendance_id  Int              @id @default(autoincrement())
  user_id        Int
  date           DateTime         @db.Date
  check_in       DateTime?        @db.Timestamptz(6)
  check_out      DateTime?        @db.Timestamptz(6)
  status         String           @default("present") @db.VarChar(50)
  leave_id       Int?
  total_hours    Decimal?         @db.Decimal(5, 2)
  device_id      Int?
  devices        devices?         @relation(fields: [device_id], references: [device_id], onUpdate: NoAction, map: "fk_attendance_device")
  leave_request  leave_request?   @relation(fields: [leave_id], references: [leave_id], onUpdate: NoAction, map: "fk_attendance_leave")
  users          users            @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_attendance_user")
  attendance_log attendance_log[]

  @@unique([user_id, date], map: "uq_attendance_user_date")
}

model attendance_log {
  log_id        Int         @id @default(autoincrement())
  user_id       Int
  scan_time     DateTime    @db.Timestamptz(6)
  scan_type     String      @db.VarChar(10)
  device_id     Int?
  scan_serial   String?     @db.VarChar(100)
  attendance_id Int?
  scan_time_myt DateTime?   @default(dbgenerated("(scan_time AT TIME ZONE 'Asia/Kuala_Lumpur'::text)")) @db.Timestamp(6)
  attendance    attendance? @relation(fields: [attendance_id], references: [attendance_id], onUpdate: NoAction, map: "fk_attendance_log_attendance")
  devices       devices?    @relation(fields: [device_id], references: [device_id], onUpdate: NoAction, map: "fk_log_device")
  users         users       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_log_user")

  @@unique([device_id, scan_serial], map: "uq_attendance_log_device_serial", where: raw("(scan_serial IS NOT NULL)"))
}

model bank_details {
  bank_id      Int     @id @default(autoincrement())
  user_id      Int     @unique
  bank_name    String? @db.VarChar(100)
  bank_account String? @db.VarChar(50)
  account_name String? @db.VarChar(200)
  users        users   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bank_user")
}

model branch {
  branch_id         Int                 @id @default(autoincrement())
  branch_name       String              @db.VarChar(100)
  location          String?             @db.VarChar(255)
  branch_code       String?             @unique @db.VarChar(10)
  region            String?             @db.VarChar(10)
  devices           devices[]
  employment        employment[]
  manpower_schedule manpower_schedule[]
}

model department {
  department_id   Int          @id @default(autoincrement())
  department_name String       @db.VarChar(100)
  department_code String       @unique @db.VarChar(10)
  employment      employment[]
}

model devices {
  device_id      Int              @id @default(autoincrement())
  serial_no      String           @unique @db.VarChar(100)
  branch_id      Int?
  ip_address     String?          @db.VarChar(45)
  attendance     attendance[]
  attendance_log attendance_log[]
  branch         branch?          @relation(fields: [branch_id], references: [branch_id], onUpdate: NoAction, map: "fk_devices_branch")
}

model emergency_contact {
  contract_id Int     @id(map: "emergency_contract_pkey") @default(autoincrement())
  user_id     Int
  name        String  @db.VarChar(255)
  phone       String? @db.VarChar(30)
  relation    String? @db.VarChar(50)
  users       users   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_contract_user")
}

model employment {
  employment_id   Int         @id @default(autoincrement())
  user_id         Int
  employee_id     String?     @unique @db.VarChar(50)
  branch_id       Int?
  department_id   Int?
  position        String?     @db.VarChar(100)
  start_date      DateTime?   @db.Date
  end_date        DateTime?   @db.Date
  employment_type String?     @db.VarChar(50)
  status          String?     @default("active") @db.VarChar(50)
  probation       Boolean     @default(false)
  rate            String?     @db.VarChar(100)
  branch          branch?     @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employment_branch")
  department      department? @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_employment_department")
  users           users       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_employment_user")
}

model leave_request {
  leave_id                               Int          @id @default(autoincrement())
  user_id                                Int
  leave_type_id                          Int
  start_date                             DateTime     @db.Date
  end_date                               DateTime     @db.Date
  total_days                             Decimal      @db.Decimal(5, 2)
  reason                                 String?
  attachment                             String?      @db.VarChar(255)
  status                                 String       @default("pending") @db.VarChar(50)
  applied_at                             DateTime     @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime     @default(now()) @db.Timestamptz(6)
  approved_by                            Int?
  approved_at                            DateTime?    @db.Timestamptz(6)
  remarks                                String?
  attendance                             attendance[]
  users_leave_request_approved_byTousers users?       @relation("leave_request_approved_byTousers", fields: [approved_by], references: [user_id], onUpdate: NoAction, map: "fk_leave_approver")
  leave_types                            leave_types  @relation(fields: [leave_type_id], references: [leave_type_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_leave_type")
  users_leave_request_user_idTousers     users        @relation("leave_request_user_idTousers", fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_leave_user")
}

model leave_types {
  leave_type_id   Int             @id @default(autoincrement())
  leave_type_code String          @unique @db.VarChar(10)
  name            String          @db.VarChar(100)
  leave_request   leave_request[]
}

model role {
  role_id   Int     @id @default(autoincrement())
  role_type String  @unique @db.VarChar(50)
  users     users[]
}

model user_profile {
  profile_id   Int       @id @default(autoincrement())
  user_id      Int       @unique
  full_name    String    @db.VarChar(255)
  nick_name    String?   @db.VarChar(255)
  gender       String?   @db.VarChar(20)
  dob          DateTime? @db.Date
  phone        String?   @db.VarChar(30)
  nationality  String?   @db.VarChar(100)
  nric         String?   @unique @db.VarChar(30)
  home_address String?
  users        users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_profile_user")
}

model users {
  user_id                                        Int                 @id @default(autoincrement())
  email                                          String              @unique @db.VarChar(255)
  password                                       String?             @db.VarChar(255)
  role_id                                        Int
  status                                         String?             @default("active") @db.VarChar(50)
  last_login                                     DateTime?           @db.Timestamptz(6)
  created_at                                     DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                                     DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at                                     DateTime?           @db.Timestamptz(6)
  attendance                                     attendance[]
  attendance_log                                 attendance_log[]
  bank_details                                   bank_details?
  claim                                          claim[]
  emergency_contact                              emergency_contact[]
  employment                                     employment[]
  leave_request_leave_request_approved_byTousers leave_request[]     @relation("leave_request_approved_byTousers")
  leave_request_leave_request_user_idTousers     leave_request[]     @relation("leave_request_user_idTousers")
  manpower_cost                                  manpower_cost[]
  manpower_schedule                              manpower_schedule[]
  user_profile                                   user_profile?
  role                                           role                @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_role")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model claim {
  claim_id          Int      @id @default(autoincrement())
  claim_type        String   @db.VarChar(20)
  claim_description String?
  amount            Decimal  @db.Decimal(10, 2)
  claim_date        DateTime @db.Date
  status            String   @default("pending") @db.VarChar(20)
  attachment        String?  @db.VarChar(500)
  submitted_on      DateTime @default(now()) @db.Timestamptz(6)
  approved_amount   Decimal? @db.Decimal(10, 2)
  remarks           String?
  user_id           Int
  updated_at        DateTime @default(now()) @db.Timestamptz(6)
  users             users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_claim_user")

  @@index([claim_date], map: "idx_claim_date")
  @@index([status], map: "idx_claim_status")
  @@index([user_id], map: "idx_claim_user_id")
}

model manpower_cost {
  manpower_cost_id Int      @id @default(autoincrement())
  user_id          Int
  date             DateTime @db.Date
  hours            Decimal  @default(0) @db.Decimal(5, 2)
  total            Decimal  @default(0) @db.Decimal(10, 2)
  users            users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_manpower_cost_user")

  @@unique([user_id, date], map: "uq_manpower_cost_user_date")
  @@index([date], map: "idx_manpower_cost_date")
  @@index([user_id, date(sort: Desc)], map: "idx_manpower_cost_user_date")
}

model manpower_schedule {
  manpower_id         Int      @id @default(autoincrement())
  branch_id           Int
  user_id             Int
  start_date          DateTime @db.Date
  end_date            DateTime @db.Date
  selections          Json     @default("{}")
  notes               Json     @default("{}")
  original_selections Json     @default("{}")
  original_notes      Json     @default("{}")
  status              String   @default("Finalized") @db.VarChar(50)
  submitted_at        DateTime @default(now()) @db.Timestamptz(6)
  branch              branch   @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_manpower_schedule_branch")
  users               users    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_manpower_schedule_user")

  @@unique([branch_id, start_date], map: "uq_manpower_schedule_branch_week")
  @@index([branch_id, start_date(sort: Desc)], map: "idx_manpower_schedule_branch_date")
  @@index([status], map: "idx_manpower_schedule_status")
}
